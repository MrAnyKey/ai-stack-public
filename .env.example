# Non-secret runtime knobs shared by host services.
# Copy to .env and edit. Keep real .env out of git.

LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000

LLAMA_SWAP_HOST=127.0.0.1
LLAMA_SWAP_PORT=8081
LLAMA_SWAP_API_BASE=http://127.0.0.1:8081/v1

SEARXNG_SEARCH_API_BASE=http://127.0.0.1:8080/search
SEARXNG_FORMATS=html,json

LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SWAP_MODEL_TTL=300

LITELLM_BACKGROUND_HEALTH_CHECKS=false
LITELLM_ENABLE_HEALTH_CHECK_ROUTING=false
LITELLM_HEALTH_CHECK_INTERVAL=300

LITELLM_DB_PORT=5432
