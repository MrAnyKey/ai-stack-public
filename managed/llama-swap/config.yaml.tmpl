# llama-swap config — https://github.com/mostlygeek/llama-swap
# llama-swap assigns per-model upstream ports dynamically via ${PORT}.
{{ $llamaServerHost := env "LLAMA_SERVER_HOST" | default "127.0.0.1" -}}
{{ $llamaSwapModelTtl := env "LLAMA_SWAP_MODEL_TTL" | default "300" -}}
{{ $libPathKey := "LD_LIBRARY_PATH" -}}
{{ if eq .chezmoi.os "darwin" -}}
{{ $libPathKey = "DYLD_FALLBACK_LIBRARY_PATH" -}}
{{ end -}}

models:
  "nomic-embed-text":
    cmd: >-
      {{ .chezmoi.destDir }}/llama-cpp/llama-server
      -m {{ .chezmoi.destDir }}/models/nomic-embed-text/nomic-embed-text-v1.5.Q8_0.gguf
      --embedding
      --ctx-size 2048
      --batch-size 2048
      --ubatch-size 2048
      --cache-ram 0
      --ctx-checkpoints 1
      --n-gpu-layers 99
      --host {{ $llamaServerHost }}
      --port ${PORT}
    env:
      {{ if ne .chezmoi.os "darwin" -}}
      - "CUDA_VISIBLE_DEVICES=0"
      {{ end -}}
      - "{{ $libPathKey }}={{ .chezmoi.destDir }}/llama-cpp"
    ttl: {{ $llamaSwapModelTtl }}
    proxy: http://{{ $llamaServerHost }}:${PORT}

  "glm-4.7-flash":
