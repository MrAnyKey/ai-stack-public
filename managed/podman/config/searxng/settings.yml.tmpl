# SearXNG settings managed by repo-local chezmoi.

use_default_settings:
  engines:
    remove:
      # Tor / niche engines that often fail in local, non-proxied setups.
      - ahmia
      - torch
      # Current upstream init can fail with KeyError: 'name'.
      - wikidata
      # Public engines that frequently return 403/429 from a single local IP.
      - brave
      - brave.images
      - brave.videos
      - brave.news
      - karmasearch
      - karmasearch images
      - karmasearch videos
      - karmasearch news

general:
  debug: false
  instance_name: "SearXNG"
  enable_metrics: false
  open_metrics: ""

search:
  safe_search: 2
  autocomplete: "duckduckgo"
  default_lang: "auto"
  formats:
    - html
    - json
  ban_time_on_fail: 5
  max_ban_time_on_fail: 120
  suspended_times:
    SearxEngineAccessDenied: 180
    SearxEngineCaptcha: 3600
    SearxEngineTooManyRequests: 180
    cf_SearxEngineCaptcha: 1296000
    cf_SearxEngineAccessDenied: 86400
    recaptcha_SearxEngineCaptcha: 604800

server:
  # Overwritten by ${SEARXNG_BASE_URL}.
  base_url: { ? { env "SEARXNG_BASE_URL" } }
  # Overwritten by ${SEARXNG_SECRET}.
  secret_key: "ultrasecretkey"
  limiter: false
  public_instance: false
  image_proxy: true
  method: "GET"
  bind_address: "0.0.0.0"
  default_http_headers:
    X-Content-Type-Options: nosniff
    X-Download-Options: noopen
    X-Robots-Tag: noindex, nofollow
    Referrer-Policy: no-referrer

ui:
  static_use_hash: true

outgoing:
  request_timeout: 3.0
  max_request_timeout: 10.0
  pool_connections: 100
  pool_maxsize: 20
  enable_http2: true

plugins:
  searx.plugins.calculator.SXNGPlugin:
    active: true
  searx.plugins.hash_plugin.SXNGPlugin:
    active: true
  searx.plugins.self_info.SXNGPlugin:
    active: false
