# Reference for manual .env. Runtime litellm/.env can also be generated from
# KeePassXC via chezmoi. Keep litellm/.env out of git.

LITELLM_MASTER_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Either hardcode DATABASE_URL here, or generate it from KeePassXC LiteLLM attrs:
# DB_NAME, DB_HOST, DB_USER, DB_PASSWORD.
# DATABASE_URL=postgresql://litellm_user:REPLACE_ME@127.0.0.1:5432/litellm
